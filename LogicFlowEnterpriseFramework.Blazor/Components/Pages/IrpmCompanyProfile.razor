@code {
    private static readonly IReadOnlyList<string> Months =
    [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    ];

    private readonly IReadOnlyList<IrpmSection> _sections =
    [
        new("overview", "irpm-overview", "01", "Company Overview", "Core identity and background"),
        new("registration", "irpm-registration", "02", "Registration & Address", "Statutory and registered address"),
        new("people", "irpm-people", "03", "People & Contacts", "Directors, contacts, authorised people"),
        new("finance", "irpm-finance", "04", "Account Information", "Company account, disbursement, voucher"),
        new("documents", "irpm-documents", "05", "Documents & Sector", "Uploads and classification")
    ];

    [SupplyParameterFromQuery]
    public string? Company { get; set; }

    private IrpmCompanyDraft _draft = new();
    private IrpmCompanyContext _companyContext = new(string.Empty, "IRPM Company Profile", string.Empty, string.Empty, string.Empty, "Migrated Company", string.Empty);
    private CompanyProfileIrpmModel? _profile;
    private string _activeSection = "overview";
    private string? _successMessage;
    private DateTimeOffset? _lastSavedAt;
    private bool _isSubmitted;
    private bool _isLoading = true;
    private string? _error;
    private bool _isDirectorEditorOpen;
    private DirectorPreview _directorEditor = new(string.Empty, string.Empty, string.Empty, "0.00%");
    private DirectorPreview? _editingDirector;
    private DirectorPreview? _directorPendingRemoval;
    private bool _isContactEditorOpen;
    private ContactPreview _contactEditor = new(string.Empty, string.Empty, string.Empty, string.Empty, string.Empty);
    private ContactPreview? _editingContact;
    private ContactPreview? _contactPendingRemoval;
    private DotNetObjectReference<IrpmCompanyProfile>? _scrollSpyReference;
    private bool _scrollSpyInitialized;

    private int UploadedDocumentCount => _draft.Documents.Count(static document => document.HasBinaryContent);
    private int CompletedSectionCount => _sections.Count(section => IsSectionComplete(section.Key));
    private int CompletionPercent => (int)Math.Round((double)CompletedSectionCount / _sections.Count * 100d, MidpointRounding.AwayFromZero);
    private int SelectedSectorCount => _draft.Sectors.Count(static sector => sector.Selected);
    private string WorkflowProgressLabel => $"{CompletedSectionCount} of {_sections.Count} profile sections complete";
    private bool CanSaveDirector => HasText(_directorEditor.Name) && HasText(_directorEditor.Designation) && HasText(_directorEditor.Nationality);
    private bool CanSaveContact => HasText(_contactEditor.Name) && HasText(_contactEditor.Designation) && HasText(_contactEditor.Email);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        _activeSection = "overview";
        _successMessage = null;
        _lastSavedAt = null;
        _isSubmitted = false;
        CloseDirectorEditor();
        CloseContactEditor();
        await DisposeScrollSpyAsync();

        try
        {
            var companyId = await ResolveCompanyIdAsync();
            if (!companyId.HasValue)
            {
                _profile = null;
                _draft = new IrpmCompanyDraft();
                _companyContext = new IrpmCompanyContext(string.Empty, "IRPM Company Profile", string.Empty, string.Empty, string.Empty, "Migrated Company", "No migrated company could be resolved for this IRPM page.");
                _error = "No migrated company profile could be resolved for the requested IRPM workspace.";
                return;
            }

            var response = await ApiClient.GetCompanyProfileIrpmAsync(companyId.Value);
            if (!response.Succeeded || response.Data is null)
            {
                _profile = null;
                _draft = new IrpmCompanyDraft();
                _companyContext = new IrpmCompanyContext(string.Empty, "IRPM Company Profile", string.Empty, string.Empty, string.Empty, "Migrated Company", string.Empty);
                _error = response.Message ?? "Unable to load the migrated IRPM company profile.";
                return;
            }

            _profile = response.Data;
            _draft = CreateDraftFromMigratedProfile(response.Data);
            _companyContext = CreateCompanyContext(response.Data, Company);
        }
        catch (Exception exception)
        {
            _profile = null;
            _draft = new IrpmCompanyDraft();
            _companyContext = new IrpmCompanyContext(string.Empty, "IRPM Company Profile", string.Empty, string.Empty, string.Empty, "Migrated Company", string.Empty);
            _error = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!Session.IsAuthenticated || _isLoading || !string.IsNullOrWhiteSpace(_error) || _profile is null || _scrollSpyInitialized)
        {
            return;
        }

        _scrollSpyReference ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync(
            "logicFlowPage.initIrpmScrollSpy",
            _scrollSpyReference,
            _sections.Select(section => new { key = section.Key, anchor = section.Anchor }).ToArray());
        _scrollSpyInitialized = true;
    }

    private void SaveDraft()
    {
        _lastSavedAt = DateTimeOffset.Now;
        _isSubmitted = CompletedSectionCount == _sections.Count;
        _successMessage = _isSubmitted
            ? $"Local IRPM draft saved at {FormatTimestamp(_lastSavedAt)}. All bound sections currently have data."
            : $"Local IRPM draft saved at {FormatTimestamp(_lastSavedAt)}. Remaining sections can be refined before backend wiring.";
    }

    private async Task ResetDraft()
    {
        await LoadAsync();
        if (string.IsNullOrWhiteSpace(_error))
        {
            _successMessage = "Latest migrated company data reloaded into the IRPM workspace.";
        }
    }

