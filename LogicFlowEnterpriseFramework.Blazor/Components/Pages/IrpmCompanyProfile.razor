                                        <strong>@_draft.BankAccounts.Count</strong>
                                        <small>Existing Accounts</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>Profile</strong>
                                        <small>Company Level</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="irpm-readonly-note irpm-finance-note">
                            <strong>Note:</strong>
                            <p>Bank account company for disbursement.</p>
                        </div>
