                                                    <td>@voucher.value.VoucherNumber</td>
                                                    <td>@voucher.value.ApplicationFor</td>
                                                    <td>@voucher.value.ApplicationType</td>
                                                    <td>@voucher.value.ExpiryDate</td>
                                                    <td>@voucher.value.Status</td>
                                                    <td>@voucher.value.Remarks</td>
                                                    <td>@voucher.value.RefundApplicationNumber</td>
                                                    <td>@voucher.value.SupportingDocument</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </article>
                </div>
            </section>

            <section id="irpm-documents" class="data-panel irpm-section">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">05 Documents</p>
                        <h2>Documents &amp; Sector</h2>
                        <p>Review supporting documents and sector tagging so the company profile is submission-ready.</p>
                    </div>
                    <span class="@GetSectionBadgeClass("documents")">@GetSectionStatusLabel("documents")</span>
                </div>

                <div class="irpm-card-grid irpm-card-grid--documents">
                    <article class="irpm-subcard irpm-subcard--readonly-feature irpm-documents-card">
                        <div class="irpm-subcard-header irpm-subcard-header--stacked">
                            <div class="irpm-contact-hero">
                                <div class="irpm-contact-title-block">
                                    <p class="eyebrow">Migrated Documents</p>
                                    <h3>Synced Documents</h3>
                                    <p>@($"{UploadedDocumentCount} of {_draft.Documents.Count} document rows are currently available from migrated attachment metadata.")</p>
                                </div>
                                <div class="irpm-contact-summary" aria-label="Synced documents summary">
                                    <div class="irpm-contact-summary-chip">
                                        <strong>@_draft.Documents.Count</strong>
                                        <small>Document Rows</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>@_draft.Documents.Count(document => document.HasBinaryContent)</strong>
                                        <small>Binary Files</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="irpm-readonly-note irpm-documents-note">
                            <strong>Download supports migrated content and metadata</strong>
                            <p>Where the original attachment binary exists it will be downloaded directly. Otherwise IRPM will generate a metadata receipt for the migrated document row.</p>
                        </div>
                        <div class="irpm-checklist irpm-documents-list">
                            @if (_draft.Documents.Count == 0)
                            {
                                <div class="irpm-placeholder-card irpm-documents-placeholder-card">
                                    <strong>No migrated documents found</strong>
                                    <p>Run the company related data sync to populate migrated attachment metadata for this company.</p>
                                </div>
                            }
                            else
                            {
                                <div class="enterprise-table-scroll irpm-documents-enterprise-scroll">
                                    <table class="enterprise-editable-table irpm-documents-enterprise-table">
                                        <thead>
                                            <tr>
                                                <th style="width:72px">No.</th>
                                                <th style="width:280px">Document</th>
                                                <th style="width:170px">Format</th>
                                                <th style="width:190px">Availability</th>
                                                <th style="width:170px">Last Synced</th>
                                                <th class="enterprise-table-actions-column">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var document in _draft.Documents.Select((value, index) => new { value, index }))
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="irpm-director-table-no">@($"{document.index + 1:00}")</span>
                                                    </td>
                                                    <td>
                                                        <span class="enterprise-table-primary">@document.value.Name</span>
                                                        <span class="irpm-director-table-subtext">@document.value.Note</span>
                                                    </td>
                                                    <td>
                                                        <span class="irpm-director-table-pill">@(string.IsNullOrWhiteSpace(document.value.FileType) ? "Unknown" : document.value.FileType)</span>
                                                    </td>
                                                    <td>
                                                        <span class="@(document.value.HasBinaryContent ? "table-badge table-badge--success" : "table-badge table-badge--info")">@(document.value.HasBinaryContent ? "Binary Ready" : "Metadata Only")</span>
                                                    </td>
                                                    <td>
                                                        <span class="irpm-contact-person-cell">@FormatDraftDate(document.value.LastSyncedAt)</span>
                                                    </td>
                                                    <td class="enterprise-row-actions">
                                                        <button class="button ghost" type="button" @onclick="@(() => DownloadDocumentAsync(document.value))">Download</button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </article>

                    <article class="irpm-subcard irpm-subcard--readonly-feature irpm-documents-card irpm-documents-card--planned">
                        <div class="irpm-subcard-header irpm-subcard-header--stacked">
                            <div class="irpm-contact-hero">
                                <div class="irpm-contact-title-block">
                                    <p class="eyebrow">Classification</p>
                                    <h3>Sector Classification</h3>
                                    <p>Sector binding is not available from the migrated company dataset yet.</p>
                                </div>
                                <div class="irpm-contact-summary" aria-label="Sector classification summary">
                                    <div class="irpm-contact-summary-chip">
                                        <strong>@_draft.Sectors.Count</strong>
                                        <small>Bound Sectors</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>Planned</strong>
                                        <small>Source Status</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="irpm-readonly-note irpm-documents-note">
                            <strong>Reserved for sector-source binding</strong>
                            <p>This section will be activated once sector-classification source tables are defined and mapped into the framework dataset.</p>
                        </div>
                        <div class="irpm-documents-placeholder-grid">
                            <div class="irpm-documents-placeholder-tile">
                                <span>Sector Tags</span>
                                <strong>Primary industry mapping</strong>
                                <p>Bind IRPM sector labels and submission categories to the migrated company profile.</p>
                            </div>
                            <div class="irpm-documents-placeholder-tile">
                                <span>Submission Readiness</span>
                                <strong>Classification controls</strong>
                                <p>Drive workflow rules, document requirements, and regulatory routing from sector assignments.</p>
                            </div>
                        </div>
                    </article>
                </div>
            </section>
        </div>
    </div>
    </div>
    }
}

