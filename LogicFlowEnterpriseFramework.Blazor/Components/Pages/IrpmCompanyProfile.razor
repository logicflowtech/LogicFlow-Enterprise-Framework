                            {
                                <div class="irpm-placeholder-card irpm-finance-placeholder-card">
                                    <strong>No existing account rows available</strong>
                                    <p>Add or bind company disbursement accounts here. Detailed financing structures can still be reviewed in the Financial Details page.</p>
                                    <button class="button ghost" type="button" @onclick="@(() => Navigation.NavigateTo(BuildFinancialDetailsUrl()))">Open Financial Details</button>
                                </div>
                            }
                            else
                            {
                                <div class="enterprise-table-scroll irpm-finance-enterprise-scroll">
                                    <table class="enterprise-editable-table irpm-finance-enterprise-table">
                                        <thead>
                                            <tr>
                                                <th style="width:72px">Bil.</th>
                                                <th style="width:240px">Bank Name</th>
                                                <th style="width:160px">Swift Code</th>
                                                <th style="width:340px">Beneficiary Name</th>
                                                <th style="width:240px">Beneficiary Account Number</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var account in _draft.BankAccounts.Select((value, index) => new { value, index }))
                                            {
                                                <tr>
                                                    <td><span class="irpm-director-table-no">@($"{account.index + 1}.")</span></td>
                                                    <td><span class="enterprise-table-primary">@account.value.BankName</span></td>
                                                    <td><span class="irpm-director-table-pill">@account.value.SwiftCode</span></td>
                                                    <td><span class="irpm-contact-person-cell">@account.value.BeneficiaryName</span></td>
                                                    <td><span class="irpm-contact-person-cell">@account.value.AccountNumber</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </article>

                    <article class="irpm-subcard irpm-subcard--readonly-feature irpm-finance-card">
                        <div class="irpm-subcard-header irpm-subcard-header--stacked">
                            <div class="irpm-contact-hero">
                                <div class="irpm-contact-title-block">
                                    <p class="eyebrow">Financial Institution Disbursement</p>
                                    <h3>Loan-Associated Account</h3>
                                    <p>Bank account associated with company loan disbursement, where applicable.</p>
                                </div>
