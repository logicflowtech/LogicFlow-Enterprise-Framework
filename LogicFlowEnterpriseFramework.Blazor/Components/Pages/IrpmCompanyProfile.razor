@page "/irpm/company-profile"
@inject AuthSession Session
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject LogicFlowApiClient ApiClient
@implements IAsyncDisposable

<PageTitle>IRPM Company Profile</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="/irpm-company-profile.css?v=enterprise-2" />
</HeadContent>

@if (!Session.IsReady)
{
    <PageLoadingShell Title="Loading session" Message="Restoring your authenticated workspace." />
}
else if (!Session.IsAuthenticated)
{
    <section class="empty-state">
        <h1>Authentication required</h1>
        <p>Sign in to access the IRPM company profile workspace.</p>
        <button class="button primary" type="button" @onclick="@(() => Navigation.NavigateTo("/login"))">Sign In</button>
    </section>
}
else
{
    @if (_isLoading)
    {
        <section class="irpm-loading-shell application-form-skeleton" aria-label="Loading company profile">
            <div class="irpm-loading-hero">
                <div class="irpm-loading-copy">
                    <div class="application-skeleton-line application-skeleton-title"></div>
                    <div class="application-skeleton-line application-skeleton-value"></div>
                    <div class="application-skeleton-line application-skeleton-helper"></div>
                    <div class="application-skeleton-line application-skeleton-helper application-skeleton-helper--short"></div>
                </div>
                <div class="irpm-loading-actions">
                    <div class="application-skeleton-button application-skeleton-button--ghost"></div>
                    <div class="application-skeleton-button application-skeleton-button--ghost"></div>
                    <div class="application-skeleton-button application-skeleton-button--ghost"></div>
                </div>
            </div>

            <div class="irpm-loading-tabs">
                <div class="application-skeleton-pill"></div>
                <div class="application-skeleton-pill"></div>
                <div class="application-skeleton-pill"></div>
                <div class="application-skeleton-pill"></div>
            </div>

            <div class="irpm-loading-summary">
                <div class="irpm-loading-summary-card">
                    <div class="application-skeleton-line application-skeleton-label"></div>
                    <div class="application-skeleton-line application-skeleton-value application-skeleton-value--short"></div>
                </div>
                <div class="irpm-loading-summary-card">
                    <div class="application-skeleton-line application-skeleton-label"></div>
                    <div class="application-skeleton-line application-skeleton-value application-skeleton-value--short"></div>
                </div>
                <div class="irpm-loading-summary-card">
                    <div class="application-skeleton-line application-skeleton-label"></div>
                    <div class="application-skeleton-line application-skeleton-value application-skeleton-value--short"></div>
                </div>
            </div>

            <div class="irpm-loading-page-shell">
                <aside class="irpm-loading-rail">
                    <div class="application-skeleton-line application-skeleton-progress-title"></div>
                    <div class="irpm-loading-nav-list">
                        @for (var navIndex = 0; navIndex < 5; navIndex++)
                        {
                            <div class="irpm-loading-nav-item">
                                <div class="application-skeleton-line application-skeleton-step"></div>
                                <div class="application-skeleton-line application-skeleton-step-long"></div>
                            </div>
                        }
                    </div>
                </aside>

                <div class="irpm-loading-sections">
                    @for (var sectionIndex = 0; sectionIndex < 3; sectionIndex++)
                    {
                        <section class="irpm-loading-section-card">
                            <div class="irpm-loading-section-header">
                                <div class="application-skeleton-line application-skeleton-section-title"></div>
                                <div class="application-skeleton-pill"></div>
                            </div>
                            <div class="irpm-loading-grid">
                                @for (var fieldIndex = 0; fieldIndex < 6; fieldIndex++)
                                {
                                    <div class="application-skeleton-input @(fieldIndex == 4 ? "irpm-loading-field-wide" : string.Empty)"></div>
                                }
                            </div>
                        </section>
                    }
                </div>
            </div>

            <div class="irpm-loading-caption">
                <strong>Preparing IRPM company profile</strong>
                <span>Loading registration, people, governance, and linked company data.</span>
            </div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="data-panel">
            <div class="alert-error">@_error</div>
        </section>
    }
    else
    {
    <div class="irpm-enterprise-page">
    <section class="page-intro irpm-page-intro">
        <div>
            <div class="application-breadcrumb">
                <span>Dashboard</span>
                <span>&gt;</span>
                <span>IRPM</span>
                <span>&gt;</span>
                <span>Company Profile</span>
            </div>
            <p class="eyebrow">Company master record</p>
            <h1>@_companyContext.CompanyName</h1>
            <p>IRPM profile record for statutory identity, governance, authorised access, and submission readiness.</p>
            <div class="irpm-hero-meta" aria-label="Company profile summary">
                <div class="irpm-hero-meta-item">
                    <span>Registration</span>
                    <strong>@_draft.RegistrationNo</strong>
                </div>
                <div class="irpm-hero-meta-item">
                    <span>Sector</span>
                    <strong>@_companyContext.Sector</strong>
                </div>
                <div class="irpm-hero-meta-item">
                    <span>Last Saved</span>
                    <strong>@FormatTimestamp(_lastSavedAt)</strong>
                </div>
            </div>
        </div>
        <div class="page-intro-actions">
            <button class="button ghost" type="button" @onclick="@(() => Navigation.NavigateTo("/dashboard"))">Back to Dashboard</button>
            <button class="button ghost" type="button" @onclick="ResetDraft">Reload Source Data</button>
            <button class="button primary irpm-button-primary" type="button" @onclick="SaveDraft">Save Draft</button>
            <span class="@GetHeroStatusClass()">@GetHeroStatusText()</span>
        </div>
    </section>

    <IrpmModuleTabs ActiveModule="company-profile" Company="@Company" />

    <section class="summary-strip irpm-summary-strip">
        <article class="summary-card irpm-summary-card">
            <span>Company</span>
            <strong>@_draft.CompanyName</strong>
            <p>@($"{_draft.RegistrationNo} - {_draft.State}, {_draft.Country}")</p>
        </article>
        <article class="summary-card irpm-summary-card">
            <span>Profile Readiness</span>
            <strong>@($"{CompletionPercent}% complete")</strong>
            <p>@FormatDraftStatusLine()</p>
        </article>
        <article class="summary-card irpm-summary-card">
            <span>Governance &amp; Access</span>
            <strong>@($"{_draft.ContactPersons.Count} contacts / {_draft.Directors.Count} directors")</strong>
            <p>@($"{UploadedDocumentCount} documents marked uploaded across {SelectedSectorCount} selected sector tags.")</p>
        </article>
    </section>

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <section class="data-panel">
            <div class="alert-success">@_successMessage</div>
        </section>
    }

    <div class="irpm-page-shell">
        <section class="data-panel irpm-section-rail">
            <div class="irpm-section-rail-header">
                <div>
                    <p class="irpm-workflow-kicker">Company profile workflow</p>
                    <h2>Complete your company record</h2>
                </div>
                <div class="irpm-workflow-progress" aria-label="@WorkflowProgressLabel">
                    <div>
                        <strong>@CompletedSectionCount of @_sections.Count</strong>
                        <span>sections complete</span>
                    </div>
                    <span class="irpm-workflow-progress-track" aria-hidden="true">
                        <span class="irpm-workflow-progress-value" style="width: @CompletionPercent%"></span>
                    </span>
                </div>
            </div>

            <ol class="irpm-nav-list">
                @foreach (var navItem in _sections)
                {
                    <li class="@(navItem.Key == _activeSection ? "is-active" : string.Empty)">
                        <button type="button" class="irpm-nav-button" @onclick="() => ScrollToSectionAsync(navItem)" aria-current="@(navItem.Key == _activeSection ? "true" : "false")">
                            <span class="irpm-nav-index">@navItem.Number</span>
                            <span class="irpm-nav-copy">
                                <strong>@GetCompactNavTitle(navItem.Key)</strong>
                            </span>
                            <span class="irpm-nav-status">
                                <span class="@GetSectionStatusDotClass(navItem.Key)" aria-hidden="true"></span>
                                <span>@GetSectionStatusLabel(navItem.Key)</span>
                            </span>
                        </button>
                    </li>
                }
            </ol>
        </section>

        <div class="irpm-content-stack">
            <section id="irpm-overview" class="data-panel irpm-section">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">01 Overview</p>
                        <h2>Company Overview</h2>
                        <p>Capture the legal identity and operating narrative that defines the company record across IRPM.</p>
                    </div>
                    <span class="@GetSectionBadgeClass("overview")">@GetSectionStatusLabel("overview")</span>
                </div>

                <div class="irpm-field-grid">
                    <label class="irpm-field irpm-field--wide">
                        <span>Company Name</span>
                        <input class="input" @bind="_draft.CompanyName" />
                    </label>
                    <label class="irpm-field">
                        <span>Company Status</span>
                        <select class="input" @bind="_draft.CompanyStatus">
                            <option>Active</option>
                            <option>Inactive</option>
                            <option>Pending Review</option>
                        </select>
                    </label>
                    <label class="irpm-field">
                        <span>Total Employment</span>
                        <input class="input" type="number" @bind="_draft.TotalEmployment" />
                    </label>
                    <label class="irpm-field">
                        <span>Phone No.</span>
                        <input class="input" @bind="_draft.PhoneNo" />
                    </label>
                    <label class="irpm-field">
                        <span>Fax No.</span>
                        <input class="input" @bind="_draft.FaxNo" />
                    </label>
                    <label class="irpm-field">
                        <span>Company Email</span>
                        <input class="input" @bind="_draft.CompanyEmail" />
                    </label>
                    <label class="irpm-field">
                        <span>Company Website</span>
                        <input class="input" @bind="_draft.CompanyWebsite" />
                    </label>
                    <label class="irpm-field irpm-field--full">
                        <span>Company Background</span>
                        <textarea class="input irpm-textarea" @bind="_draft.CompanyBackground"></textarea>
                    </label>
                </div>
            </section>

            <section id="irpm-registration" class="data-panel irpm-section">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">02 Registration</p>
                        <h2>Registration &amp; Address</h2>
                        <p>Keep statutory references and the registered address aligned with the latest SSM and tax records.</p>
                    </div>
                    <span class="@GetSectionBadgeClass("registration")">@GetSectionStatusLabel("registration")</span>
                </div>

                <div class="irpm-registration-shell">
                    <div class="irpm-card-grid irpm-card-grid--registration">
                        <article class="irpm-subcard irpm-subcard--registration">
                            <div class="irpm-subcard-header">
                                <div>
                                    <p class="eyebrow">Company Registration</p>
                                    <h3>Corporate Registration</h3>
                                    <p>Primary statutory details used for company identification, compliance reference, and official submissions.</p>
                                </div>
                            </div>
                            <div class="irpm-field-grid irpm-field-grid--registration">
                                <label class="irpm-field">
                                    <span>Registration Type</span>
                                    <input class="input" @bind="_draft.RegistrationType" />
                                </label>
                                <label class="irpm-field">
                                    <span>Registration No.</span>
                                    <input class="input" @bind="_draft.RegistrationNo" />
                                </label>
                                <label class="irpm-field irpm-field--wide">
                                    <span>New SSM Registration No.</span>
                                    <input class="input" @bind="_draft.NewSsmRegistrationNo" />
                                </label>
                                <label class="irpm-field">
                                    <span>Date of Incorporation</span>
                                    <input class="input" @bind="_draft.DateOfIncorporationText" placeholder="YYYY-MM-DD" />
                                </label>
                                <label class="irpm-field">
                                    <span>Fiscal Closing Day</span>
                                    <input class="input" type="number" min="1" max="31" @bind="_draft.AnnualClosingDay" />
                                </label>
                                <label class="irpm-field">
                                    <span>Fiscal Closing Month</span>
                                    <select class="input" @bind="_draft.AnnualClosingMonth">
                                        @foreach (var month in Months)
                                        {
                                            <option value="@month">@month</option>
                                        }
                                    </select>
                                </label>
                                <label class="irpm-field">
                                    <span>Income Tax Reference No.</span>
                                    <input class="input" @bind="_draft.IncomeTaxNo" />
                                </label>
                                <label class="irpm-field">
                                    <span>EPF No.</span>
                                    <input class="input" @bind="_draft.EpfNo" />
                                </label>
                                <label class="irpm-field">
                                    <span>SOCSO No.</span>
                                    <input class="input" @bind="_draft.SocsoNo" />
                                </label>
                                <label class="irpm-field">
                                    <span>APR Serial No.</span>
                                    <input class="input" @bind="_draft.AprSerialNo" />
                                </label>
                            </div>
                        </article>

                        <article class="irpm-subcard irpm-subcard--registration">
                            <div class="irpm-subcard-header">
                                <div>
                                    <p class="eyebrow">Registered Office</p>
                                    <h3>Address Record</h3>
                                    <p>Registered office details presented as the operational address record for this company profile.</p>
                                </div>
                            </div>
                            <div class="irpm-field-grid irpm-field-grid--registration-address">
                                <label class="irpm-field irpm-field--wide">
                                    <span>Address Line 1</span>
                                    <input class="input" @bind="_draft.AddressLine1" />
                                </label>
                                <label class="irpm-field irpm-field--wide">
                                    <span>Address Line 2</span>
                                    <input class="input" @bind="_draft.AddressLine2" />
                                </label>
                                <label class="irpm-field irpm-field--wide">
                                    <span>Address Line 3</span>
                                    <input class="input" @bind="_draft.AddressLine3" />
                                </label>
                                <label class="irpm-field">
                                    <span>Postcode</span>
                                    <input class="input" @bind="_draft.Postcode" />
                                </label>
                                <label class="irpm-field">
                                    <span>Country</span>
                                    <input class="input" @bind="_draft.Country" />
                                </label>
                                <label class="irpm-field">
                                    <span>State</span>
                                    <input class="input" @bind="_draft.State" />
                                </label>
                                <label class="irpm-field">
                                    <span>City</span>
                                    <input class="input" @bind="_draft.City" />
                                </label>
                                <label class="irpm-field">
                                    <span>Region</span>
                                    <input class="input" @bind="_draft.Region" />
                                </label>
                            </div>
                        </article>
                    </div>
                </div>
            </section>

            <section id="irpm-people" class="data-panel irpm-section">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">03 People</p>
                        <h2>People &amp; Contacts</h2>
                        <p>Track directors maintained in IRPM and surface synced login contacts with controlled company access.</p>
                    </div>
                    <span class="@GetSectionBadgeClass("people")">@GetSectionStatusLabel("people")</span>
                </div>

                <div class="irpm-people-layout">
                    <article class="irpm-subcard irpm-subcard--governance irpm-people-primary">
                        <div class="irpm-subcard-header">
                            <div>
                                <p class="eyebrow">Governance</p>
                                <h3>Board of Directors</h3>
                                <p>Maintain the board list for this company profile with direct add, edit, and remove actions.</p>
                            </div>
                            <div class="irpm-director-toolbar">
                                <div class="irpm-director-summary" aria-label="Board summary">
                                    <div class="irpm-director-summary-chip">
                                        <strong>@_draft.Directors.Count</strong>
                                        <small>Board Members</small>
                                    </div>
                                    <div class="irpm-director-summary-chip">
                                        <strong>Migrated</strong>
                                        <small>Profile Data</small>
                                    </div>
                                </div>
                                <button class="button primary irpm-button-primary" type="button" @onclick="OpenAddDirectorEditor">Add Director</button>
                            </div>
                        </div>
                        <div class="irpm-collection-list">
                            @if (_draft.Directors.Count == 0)
                            {
                                <div class="irpm-collection-empty">
                                    <strong>No directors added yet</strong>
                                    <span>Start building the board list used for this company profile.</span>
                                    <div>
                                        <button class="button primary irpm-button-primary" type="button" @onclick="OpenAddDirectorEditor">Add Director</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="enterprise-table-scroll irpm-director-enterprise-scroll">
                                    <table class="enterprise-editable-table irpm-director-enterprise-table">
                                        <thead>
                                            <tr>
                                                <th style="width:72px">No.</th>
                                                <th style="width:260px">Director</th>
                                                <th style="width:190px">Designation</th>
                                                <th style="width:150px">Nationality</th>
                                                <th style="width:130px">Shares Held</th>
                                                <th class="enterprise-table-actions-column">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var director in _draft.Directors.Select((value, index) => new { value, index }))
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="irpm-director-table-no">@($"{director.index + 1:00}")</span>
                                                    </td>
                                                    <td>
                                                        <span class="enterprise-table-primary">@director.value.Name</span>
                                                        <span class="irpm-director-table-subtext">Migrated director record</span>
                                                    </td>
                                                    <td>@director.value.Designation</td>
                                                    <td>
                                                        <span class="irpm-director-table-pill">@director.value.Nationality</span>
                                                    </td>
                                                    <td>
                                                        <span class="irpm-director-table-pill irpm-director-table-pill--shares">@director.value.SharesHeld</span>
                                                    </td>
                                                    <td class="enterprise-row-actions">
                                                        <button class="button ghost" type="button" @onclick="@(() => OpenEditDirectorEditor(director.value))">Edit</button>
                                                        <button class="style-guide-danger-button" type="button" @onclick="@(() => PromptDirectorRemoval(director.value))">Remove</button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </article>

                    <article class="irpm-subcard irpm-subcard--readonly-feature irpm-people-secondary">
                        <div class="irpm-subcard-header irpm-subcard-header--stacked">
                            <div class="irpm-contact-hero">
                                <div class="irpm-contact-title-block">
                                    <p class="eyebrow">Synced Access</p>
                                    <h3>Company Login Contacts</h3>
                                    <p>Read-only contact persons resolved from the company profile and linked framework user assignments.</p>
                                </div>
                                <div class="irpm-contact-summary" aria-label="Company login contact summary">
                                    <div class="irpm-contact-summary-chip">
                                        <strong>@_draft.ContactPersons.Count</strong>
                                        <small>Contact Persons</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>@_draft.ContactPersons.Count(contact => !string.IsNullOrWhiteSpace(contact.UserName))</strong>
                                        <small>Linked Logins</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>1 Company</strong>
                                        <small>Company Scope</small>
                                    </div>
                                </div>
                                <button class="button primary irpm-button-primary" type="button" @onclick="OpenAddContactEditor">Add Contact Person</button>
                            </div>
                        </div>
                        <div class="irpm-readonly-note">
                            <strong>Aligned to company contact persons</strong>
                            <p>Manage the contact-person list used in IRPM while preserving linked framework access for users that already exist in the platform.</p>
                        </div>
                        <div class="irpm-collection-list">
                            @if (_draft.ContactPersons.Count == 0)
                            {
                                <div class="irpm-collection-empty">
                                    <strong>No synced contact persons found</strong>
                                    <span>Run the company-contact sync or add a contact person directly for this IRPM profile.</span>
                                    <div>
                                        <button class="button primary irpm-button-primary" type="button" @onclick="OpenAddContactEditor">Add Contact Person</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="enterprise-table-scroll irpm-contact-person-enterprise-scroll">
                                    <table class="enterprise-editable-table irpm-contact-person-enterprise-table">
                                        <thead>
                                            <tr>
                                                <th style="width:72px">No.</th>
                                                <th style="width:240px">Name</th>
                                                <th style="width:200px">Designation</th>
                                                <th style="width:260px">Email</th>
                                                <th style="width:150px">Phone No.</th>
                                                <th style="width:160px">Access</th>
                                                <th class="enterprise-table-actions-column">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var contact in _draft.ContactPersons.Select((value, index) => new { value, index }))
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="irpm-director-table-no">@($"{contact.index + 1}.")</span>
                                                    </td>
                                                    <td>
                                                        <span class="enterprise-table-primary">@contact.value.Name</span>
                                                        <span class="irpm-director-table-subtext">Contact person record</span>
                                                    </td>
                                                    <td>@contact.value.Designation</td>
                                                    <td>
                                                        <span class="irpm-contact-person-cell irpm-contact-person-cell--email">@contact.value.Email</span>
                                                    </td>
                                                    <td>
                                                        <span class="irpm-contact-person-cell">@(string.IsNullOrWhiteSpace(contact.value.PhoneNo) ? "-" : contact.value.PhoneNo)</span>
                                                    </td>
                                                    <td>
                                                        <span class="table-badge @(string.IsNullOrWhiteSpace(contact.value.UserName) ? "table-badge--info" : "table-badge--success")">@(string.IsNullOrWhiteSpace(contact.value.UserName) ? "Profile Contact" : "This Company Only")</span>
                                                    </td>
                                                    <td class="enterprise-row-actions">
                                                        <button class="button ghost" type="button" @onclick="@(() => OpenEditContactEditor(contact.value))">Edit</button>
                                                        <button class="style-guide-danger-button" type="button" @onclick="@(() => PromptContactRemoval(contact.value))">Remove</button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </article>

                    <article class="irpm-subcard irpm-subcard--readonly-feature irpm-people-planned">
                        <div class="irpm-subcard-header irpm-subcard-header--stacked">
                            <div class="irpm-contact-hero">
                                <div class="irpm-contact-title-block">
                                    <p class="eyebrow">Migrated Access</p>
                                    <h3>Authorised Persons</h3>
                                    <p>Authorised persons migrated from the source company record, including certification and verification status.</p>
                                </div>
                                <div class="irpm-contact-summary" aria-label="Authorised person summary">
                                    <div class="irpm-contact-summary-chip">
                                        <strong>@_draft.AuthorizedPersons.Count</strong>
                                        <small>Authorised Persons</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>Migrated</strong>
                                        <small>Source Records</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>Read Only</strong>
                                        <small>IRPM View</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="irpm-readonly-note">
                            <strong>Bound to migrated source data</strong>
                            <p>These records are loaded from the migrated company-related data tables and displayed read-only here.</p>
                        </div>
                        <div class="irpm-collection-list">
                            @if (_draft.AuthorizedPersons.Count == 0)
                            {
                                <div class="irpm-collection-empty">
                                    <strong>No authorised persons found</strong>
                                    <span>Run the company related data sync to populate this panel.</span>
                                </div>
                            }
                            else
                            {
                                <div class="enterprise-table-scroll irpm-authorized-person-enterprise-scroll">
                                    <table class="enterprise-editable-table irpm-authorized-person-enterprise-table">
                                        <thead>
                                            <tr>
                                                <th style="width:72px">No.</th>
                                                <th style="width:260px">Authorised Person</th>
