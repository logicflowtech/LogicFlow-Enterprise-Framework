                                                <td colspan="9">
                                                    <div class="irpm-finance-empty-row">
                                                        <strong>No voucher rows available</strong>
                                                        <span>Voucher references can be introduced here when the profile workflow needs them.</span>
                                                    </div>
                                                </td>
