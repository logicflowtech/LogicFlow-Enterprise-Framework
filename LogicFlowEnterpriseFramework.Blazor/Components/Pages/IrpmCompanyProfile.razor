    private async Task DownloadDocumentAsync(DocumentRequirement document)
    {
        if (_profile is null)
        {
            return;
        }

        try
        {
            _error = null;
            var payload = await ApiClient.DownloadCompanyProfileDocumentAsync(_profile.Id, document.MigratedId);
            await JS.InvokeVoidAsync(
                "logicFlowDownloads.downloadBytes",
                payload.FileName,
                Convert.ToBase64String(payload.Content),
                payload.ContentType);

            _successMessage = document.HasBinaryContent
                ? $"Downloaded {document.Name}."
                : $"Downloaded metadata receipt for {document.Name}.";
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
    }

    private async Task ScrollToSectionAsync(IrpmSection section)
    {
        _activeSection = section.Key;
        await JS.InvokeVoidAsync("logicFlowPage.scrollToSection", section.Anchor);
    }

    [JSInvokable]
    public async Task SetActiveSectionFromScrollAsync(string? sectionKey)
    {
        if (string.IsNullOrWhiteSpace(sectionKey) || string.Equals(_activeSection, sectionKey, StringComparison.Ordinal))
        {
            return;
        }

        _activeSection = sectionKey;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DisposeScrollSpyAsync()
    {
        if (_scrollSpyInitialized)
        {
            await JS.InvokeVoidAsync("logicFlowPage.disposeIrpmScrollSpy");
            _scrollSpyInitialized = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await DisposeScrollSpyAsync();
        }
        catch
        {
            // Ignore disposal-time JS disconnects.
        }

        _scrollSpyReference?.Dispose();
    }

