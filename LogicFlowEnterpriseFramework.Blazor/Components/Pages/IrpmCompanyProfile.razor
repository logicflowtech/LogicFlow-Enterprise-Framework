    private bool IsSectionComplete(string sectionKey)
    {
        return sectionKey switch
        {
            "overview" => HasText(_draft.CompanyName)
                && HasText(_draft.CompanyStatus)
                && HasText(_draft.CompanyBackground)
                && _draft.TotalEmployment > 0,
            "registration" => HasText(_draft.RegistrationNo)
                && HasText(_draft.NewSsmRegistrationNo)
                && HasText(_draft.DateOfIncorporationText)
                && HasText(_draft.AddressLine1)
                && HasText(_draft.Postcode)
                && HasText(_draft.Country)
                && HasText(_draft.State)
                && HasText(_draft.City),
            "people" => _draft.Directors.Count > 0 && _draft.ContactPersons.Count > 0,
            "finance" => _draft.BankAccounts.Count > 0 || _draft.DisbursementAccounts.Count > 0 || _draft.Vouchers.Count > 0,
            "documents" => UploadedDocumentCount > 0,
            _ => false
        };
    }

    private static bool HasText(string? value)
    {
        return !string.IsNullOrWhiteSpace(value);
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "Not saved";
    }

    private static string FormatProfileDate(DateTime? value)
    {
        if (!value.HasValue)
        {
            return "Not available";
        }

        return new DateTimeOffset(DateTime.SpecifyKind(value.Value, DateTimeKind.Utc))
            .ToLocalTime()
            .ToString("dd MMM yyyy HH:mm");
    }

    private async Task<Guid?> ResolveCompanyIdAsync()
    {
        if (Guid.TryParse(Company, out var explicitCompanyId))
        {
            return explicitCompanyId;
        }

        if (long.TryParse(Company, out var migratedId))
        {
            var byMigratedId = await ApiClient.GetCompanyProfilesAsync(1, 100, migratedId.ToString());
            return byMigratedId.Data?.Items.FirstOrDefault(item => item.MigratedId == migratedId)?.Id;
        }

        if (!string.IsNullOrWhiteSpace(Company))
        {
            var catalogMatch = IrpmWorkspaceCatalog.ResolveCompany(Company);
            var searchTerm = !string.IsNullOrWhiteSpace(catalogMatch.CompanyName) ? catalogMatch.CompanyName : Company;
            var byName = await ApiClient.GetCompanyProfilesAsync(1, 100, searchTerm);
            var exactMatch = byName.Data?.Items.FirstOrDefault(item =>
                string.Equals(item.CompanyName, catalogMatch.CompanyName, StringComparison.OrdinalIgnoreCase));
            if (exactMatch is not null)
            {
                return exactMatch.Id;
            }

            var looseMatch = byName.Data?.Items.FirstOrDefault(item =>
                !string.IsNullOrWhiteSpace(item.CompanyName) &&
                item.CompanyName.Contains(Company, StringComparison.OrdinalIgnoreCase));
            if (looseMatch is not null)
            {
                return looseMatch.Id;
            }
        }

        var firstPage = await ApiClient.GetCompanyProfilesAsync(1, 100, null);
        return firstPage.Data?.Items.FirstOrDefault()?.Id;
    }

    private static IrpmCompanyContext CreateCompanyContext(CompanyProfileIrpmModel profile, string? companyKey)
    {
        var key = string.IsNullOrWhiteSpace(companyKey) ? profile.Id.ToString() : companyKey.Trim();
        var state = profile.Address?.State ?? string.Empty;
        var country = profile.Address?.Country ?? string.Empty;
        var sector = profile.IsCompanyLocal == true ? "Local Company" : "External Company";
        var summary = $"Migrated company profile bound from framework cache. Source company ID: {profile.MigratedId?.ToString() ?? "N/A"}.";
        return new IrpmCompanyContext(
            key,
            profile.CompanyName ?? "IRPM Company Profile",
            profile.RegistrationNo ?? string.Empty,
            state,
            country,
            sector,
            summary);
    }

    private static IrpmCompanyDraft CreateDraftFromMigratedProfile(CompanyProfileIrpmModel profile)
    {
        return new IrpmCompanyDraft
        {
            CompanyName = profile.CompanyName ?? string.Empty,
            CompanyStatus = profile.CompanyStatusId?.ToString() ?? (profile.CompanyApprovalStatus?.ToString() ?? "Not available"),
            RegistrationType = profile.CompanyType?.ToString() ?? "Not available",
            RegistrationNo = profile.RegistrationNo ?? string.Empty,
            NewSsmRegistrationNo = profile.NewSsmCompanyRegNo ?? string.Empty,
            DateOfIncorporationText = profile.DateOfIncorporation?.ToString("yyyy-MM-dd") ?? string.Empty,
            IncomeTaxNo = profile.IncomeTaxNo ?? string.Empty,
            EpfNo = profile.EpfNo ?? string.Empty,
            SocsoNo = profile.SocsoNo ?? string.Empty,
            AprSerialNo = profile.AprNo ?? string.Empty,
            AnnualClosingDay = profile.AnnualClosingDateDay ?? 0,
            AnnualClosingMonth = ResolveMonthName(profile.AnnualClosingDateMonth),
            AddressLine1 = profile.Address?.AddressLine1 ?? string.Empty,
            AddressLine2 = profile.Address?.AddressLine2 ?? string.Empty,
            AddressLine3 = profile.Address?.AddressLine3 ?? string.Empty,
            Postcode = profile.Address?.Postcode ?? string.Empty,
            Region = profile.IsCompanyLocal == true ? "Malaysia" : string.Empty,
            Country = profile.Address?.Country ?? string.Empty,
            State = profile.Address?.State ?? string.Empty,
            City = profile.Address?.City ?? string.Empty,
            PhoneNo = profile.TelephoneNo ?? string.Empty,
            FaxNo = profile.FaxNo ?? string.Empty,
            CompanyEmail = profile.Email ?? string.Empty,
            CompanyWebsite = profile.Website ?? string.Empty,
            TotalEmployment = profile.TotalEmployment ?? 0,
            CompanyBackground = profile.BackgroundDescription1 ?? string.Empty,
            Directors = profile.Directors
                .Select(item => new DirectorPreview(
                    item.Name ?? "Unnamed director",
                    item.Designation ?? "Director",
                    item.Nationality ?? "Not provided",
                    item.SharePercentage.HasValue ? $"{item.SharePercentage.Value:0.00}%" : "0.00%"))
                .ToList(),
            ContactPersons = profile.ContactPersons
                .Select(item => new ContactPreview(
                    item.FullName ?? item.UserName ?? "Unnamed contact",
                    item.Designation ?? "Not provided",
                    item.Email ?? "No email provided",
                    item.PhoneNumber ?? string.Empty,
                    item.UserName ?? string.Empty))
                .ToList(),
            AuthorizedPersons = profile.AuthorizedPersons
                .Select(item => new AuthorizedPersonPreview(
                    item.FullName ?? "Unnamed authorised person",
                    item.Designation ?? string.Empty,
                    item.Email,
                    item.TelephoneNo,
                    item.IdentityNumber,
                    BuildAuthorizedPersonStatus(item),
                    BuildAuthorizedPersonStatusClass(item),
                    BuildAuthorizedPersonSecondaryStatus(item)))
                .ToList(),
            BankAccounts = [],
            DisbursementAccounts = [],
            DigitalCertificates = profile.AuthorizedPersons
                .Select(item => new DigitalCertificatePreview(
                    item.FullName ?? "Unnamed authorised person",
                    item.Designation ?? "Not provided",
                    BuildAuthorizedPersonStatus(item),
                    BuildAuthorizedPersonStatusClass(item)))
                .ToList(),
            Vouchers = [],
            Documents = profile.Documents
                .Select(item => new DocumentRequirement(
                    item.MigratedId,
                    item.FileName ?? $"Document {item.MigratedId}",
                    string.IsNullOrWhiteSpace(item.FileType)
                        ? $"Migrated document metadata. Synced {FormatDraftDate(item.LastSyncedAt)}."
                        : $"{item.FileType} file. Synced {FormatDraftDate(item.LastSyncedAt)}.",
                    item.HasFileContent,
                    item.FileType,
                    item.LastSyncedAt))
                .ToList(),
            Sectors = []
        };
    }

    private static string ResolveMonthName(int? month)
    {
        return month.HasValue && month.Value >= 1 && month.Value <= 12
            ? Months[month.Value - 1]
            : "January";
    }

    private static string BuildAuthorizedPersonStatus(CompanyProfileIrpmAuthorizedPersonModel item)
    {
        if (item.IsCertified == true && item.IsPinVerified == true)
        {
            return "Certified";
        }

        if (item.IsCertified == true)
        {
            return "Certified / Pending PIN";
        }

        if (item.IsDigiCertPaid == true)
        {
            return "Paid / Pending Certification";
        }

        return "Pending Certification";
    }

    private static string BuildAuthorizedPersonStatusClass(CompanyProfileIrpmAuthorizedPersonModel item)
    {
        if (item.IsCertified == true && item.IsPinVerified == true)
        {
            return "table-badge table-badge--success";
        }

        if (item.IsCertified == true || item.IsDigiCertPaid == true)
        {
            return "table-badge table-badge--info";
        }

        return "table-badge table-badge--warning";
    }

    private static string BuildAuthorizedPersonSecondaryStatus(CompanyProfileIrpmAuthorizedPersonModel item)
    {
        if (item.IsDeletedInSource)
        {
            return "Marked deleted in source";
        }

        if (item.IsPinVerified == true)
        {
            return "PIN verified";
        }

        return "Awaiting PIN verification";
    }

