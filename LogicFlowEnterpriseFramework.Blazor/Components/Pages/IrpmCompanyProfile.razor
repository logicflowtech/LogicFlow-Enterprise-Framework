                                    <div class="irpm-contact-summary-chip">
                                        <strong>@_draft.DisbursementAccounts.Count</strong>
                                        <small>Disbursement Accounts</small>
                                    </div>
                                    <div class="irpm-contact-summary-chip">
                                        <strong>Linked</strong>
                                        <small>Loan Reference</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="irpm-readonly-note irpm-finance-note">
                            <strong>Note:</strong>
                            <p>Bank account associated with company loan, if applicable.</p>
                        </div>
                        <div class="irpm-metric-list irpm-finance-list">
                            @if (_draft.DisbursementAccounts.Count == 0)
                            {
                                <div class="irpm-placeholder-card irpm-finance-placeholder-card">
                                    <strong>No loan-disbursement account rows available</strong>
