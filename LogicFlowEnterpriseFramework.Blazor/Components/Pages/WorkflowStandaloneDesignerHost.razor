@page "/workflow/designer/{DefinitionId}"
@rendermode InteractiveServer
@inject AuthSession Session
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Workflow Designer</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="@GetVersionedAssetPath("/workflow-designer/assets/workflow-designer.css")" />
</HeadContent>

@if (!Session.IsReady)
{
    <section class="page-shell">
        <div class="empty-state-card compact">
            <div class="empty-state-icon">WF</div>
            <strong>Loading session</strong>
            <p>Restoring your authenticated workflow workspace.</p>
        </div>
    </section>
}
else if (!Session.IsAuthenticated || Session.User is null)
{
    <section class="page-shell">
        <div class="empty-state-card compact">
            <div class="empty-state-icon">WF</div>
            <strong>Sign in required</strong>
            <p>The workflow designer uses the current framework session.</p>
        </div>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <section class="page-shell">
        <div class="empty-state-card compact">
            <div class="empty-state-icon">WF</div>
            <strong>Workflow designer unavailable</strong>
            <p>@_loadError</p>
        </div>
    </section>
}
else if (!_isReady)
{
    <section class="page-shell">
        <div class="empty-state-card compact">
            <div class="empty-state-icon">WF</div>
            <strong>Preparing workflow designer</strong>
            <p>Loading the standalone designer workspace.</p>
        </div>
    </section>
}
else
{
    <section class="workflow-host-shell">
        <div @ref="_hostElement" class="workflow-react-host"></div>
    </section>
}

@code {
    [Parameter]
    public string DefinitionId { get; set; } = string.Empty;

    private bool _isReady;
    private bool _isMounted;
    private ElementReference _hostElement;
    private IJSObjectReference? _module;
    private string? _loadError;
    private string _assetVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString(System.Globalization.CultureInfo.InvariantCulture);

    protected override void OnInitialized()
    {
        _assetVersion = ResolveAssetVersion();
        Session.Changed += HandleSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Session.IsReady || !Session.IsAuthenticated || Session.User is null)
        {
            return;
        }

        try
        {
            if (_module is null)
            {
                _module = await JS.InvokeAsync<IJSObjectReference>("import", GetVersionedAssetPath("/workflow-designer-host.js"));
                _loadError = null;
                await _module.InvokeVoidAsync("setSession", new
                {
                    accessToken = Session.AccessToken,
                    apiBaseUrl = "/workflow-api",
                    assetVersion = _assetVersion,
                    hostMode = "designer",
                    definitionId = DefinitionId,
                    returnUrl = "/workflow/definitions",
                    user = new
                    {
                        id = Session.User.Id,
                        userName = Session.User.Email,
                        displayName = Session.User.FullName,
                        email = Session.User.Email,
                        status = "Active",
                        permissions = Session.User.Permissions
                    }
                });

                _isReady = true;
                StateHasChanged();
                return;
            }

            if (_module is not null)
            {
                await _module.InvokeVoidAsync("setSession", new
                {
                    accessToken = Session.AccessToken,
                    apiBaseUrl = "/workflow-api",
                    assetVersion = _assetVersion,
                    hostMode = "designer",
                    definitionId = DefinitionId,
                    returnUrl = "/workflow/definitions",
                    user = new
                    {
                        id = Session.User.Id,
                        userName = Session.User.Email,
                        displayName = Session.User.FullName,
                        email = Session.User.Email,
                        status = "Active",
                        permissions = Session.User.Permissions
                    }
                });
            }

            if (_isReady && !_isMounted && _module is not null)
            {
                await _module.InvokeVoidAsync("mount", _hostElement);
                _isMounted = true;
            }
        }
        catch (JSException ex)
        {
            _loadError = ex.Message;
            _isReady = false;
            _isMounted = false;
            StateHasChanged();
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private void HandleSessionChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        Session.Changed -= HandleSessionChanged;

        if (_module is null)
        {
            return;
        }

        try
        {
            await _module.InvokeVoidAsync("unmount");
            await _module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private string GetVersionedAssetPath(string assetPath) => $"{assetPath}?v={_assetVersion}";

    private string ResolveAssetVersion()
    {
        try
        {
            var cssPath = Path.Combine(AppContext.BaseDirectory, "wwwroot", "workflow-designer", "assets", "workflow-designer.css");
            var jsPath = Path.Combine(AppContext.BaseDirectory, "wwwroot", "workflow-designer", "assets", "workflow-designer.js");
            var hostPath = Path.Combine(AppContext.BaseDirectory, "wwwroot", "workflow-designer-host.js");
            var latestWrite = new[]
            {
                File.Exists(cssPath) ? File.GetLastWriteTimeUtc(cssPath).Ticks : 0L,
                File.Exists(jsPath) ? File.GetLastWriteTimeUtc(jsPath).Ticks : 0L,
                File.Exists(hostPath) ? File.GetLastWriteTimeUtc(hostPath).Ticks : 0L,
            }.Max();

            return latestWrite > 0
                ? latestWrite.ToString(System.Globalization.CultureInfo.InvariantCulture)
                : DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString(System.Globalization.CultureInfo.InvariantCulture);
        }
        catch
        {
            return DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString(System.Globalization.CultureInfo.InvariantCulture);
        }
    }
}
