    private string BuildCompanyProfileUrl()
    {
        return string.IsNullOrWhiteSpace(Company)
            ? "/irpm/company-profile"
            : $"/irpm/company-profile?company={Uri.EscapeDataString(Company)}";
    }

    private async Task ScrollToSectionAsync(SectionItem section)
    {
        _activeSection = section.Anchor;
        await JS.InvokeVoidAsync("logicFlowPage.scrollToSection", section.Anchor);
    }

    [JSInvokable]
    public async Task SetActiveSectionFromScrollAsync(string? sectionKey)
    {
        if (string.IsNullOrWhiteSpace(sectionKey) || string.Equals(_activeSection, sectionKey, StringComparison.Ordinal))
        {
            return;
        }

        _activeSection = sectionKey;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DisposeScrollSpyAsync()
    {
        if (_scrollSpyInitialized)
        {
            await JS.InvokeVoidAsync("logicFlowPage.disposeIrpmScrollSpy");
            _scrollSpyInitialized = false;
        }
    }

    private string FormatStatementOption(CompanyProfileFinancialDetailsSummaryModel statement)
    {
        var year = statement.FinancialYear?.ToString() ?? "No year";
        var effectiveDate = statement.EffectiveDate.HasValue ? $" | {statement.EffectiveDate.Value:dd MMM yyyy}" : string.Empty;
        return $"{year}{effectiveDate} | ID {statement.MigratedId}";
    }

    private static string BuildStatementLabel(CompanyProfileFinancialSelectedDetailModel? statement)
    {
        if (statement is null)
        {
            return "No statement";
        }

        return statement.FinancialYear?.ToString() ?? (statement.EffectiveDate?.ToString("dd MMM yyyy") ?? "Statement");
    }

    private string GetHeroStatusClass() => _selectedStatement is null
        ? "irpm-hero-status"
        : "irpm-hero-status irpm-hero-status--active";

    private string GetHeroStatusText() => _selectedStatement is null ? "No statement" : "Migrated data";

    private string GetSectionActionLabel(string anchor) =>
        string.Equals(_activeSection, anchor, StringComparison.Ordinal) ? "Viewing" : "View";

    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayInt(int? value) => value?.ToString() ?? "-";

    private static string DisplayLong(long? value) => value?.ToString() ?? "-";

    private static string? DisplayLongOrNull(long? value) => value?.ToString();

    private static string FormatMoney(decimal? value) => value.HasValue ? $"RM {value.Value:N2}" : "-";

    private static string FormatPercent(decimal? value) => value.HasValue ? $"{value.Value:N2}%" : "-";

    private static string FormatDate(DateTime? value) => value?.ToString("dd MMM yyyy") ?? "-";

    private static string FormatDateTime(DateTime? value) => value?.ToString("dd MMM yyyy, hh:mm tt") ?? "-";

    private static string CountLabel(int? count) => $"{count ?? 0} rows";

    public async ValueTask DisposeAsync()
    {
        try
        {
            await DisposeScrollSpyAsync();
        }
        catch
        {
            // Ignore disposal-time JS disconnects.
        }

        _scrollSpyReference?.Dispose();
    }

    private sealed record SectionItem(string Number, string Title, string Anchor);

    private sealed record CapitalRow(string Label, decimal? Amount, decimal? Percent);

    private sealed record PerformanceMetric(string Label, string Value, string? Secondary = null);
