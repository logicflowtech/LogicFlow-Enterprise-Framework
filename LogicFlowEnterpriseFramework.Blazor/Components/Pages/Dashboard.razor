@page "/dashboard"
@inject AuthSession Session
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

@if (!Session.IsReady)
{
    <PageLoadingShell Title="Loading session" Message="Restoring your authenticated workspace." />
}
else if (!Session.IsAuthenticated)
{
    <section class="empty-state">
        <h1>Authentication required</h1>
        <p>Sign in to access the enterprise dashboard.</p>
        <button class="button primary" @onclick="@(() => Navigation.NavigateTo("/login"))">Sign In</button>
    </section>
}
else
{
    <section class="page-intro">
        <div>
            <div class="application-breadcrumb">
                <span>Dashboard</span>
                <span>&gt;</span>
                <span>My Company</span>
            </div>
            <p class="eyebrow">Workspace</p>
            <h1>Welcome, @Session.User?.FullName</h1>
            <p>Review company applications, authorised persons, and task activity from one dashboard using mock data for the layout.</p>
        </div>
        <div class="page-intro-actions">
            <button class="button ghost" type="button" @onclick="@(() => Navigation.NavigateTo("/profile"))">Profile</button>
            <button class="button ghost" type="button" @onclick="@(() => Navigation.NavigateTo("/company-profiles"))">Company Profiles</button>
            <button class="button primary" type="button" @onclick="@(() => Navigation.NavigateTo("/tasks"))">View All Tasks</button>
        </div>
    </section>

    <section class="summary-strip">
        <article class="summary-card">
            <span>Companies</span>
            <strong>@Companies.Count</strong>
            <p>Registered company shells shown on this dashboard.</p>
        </article>
        <article class="summary-card">
            <span>Applications</span>
            <strong>@SelectedCompany.Applications.Count</strong>
            <p>Mock applications for the selected company.</p>
        </article>
        <article class="summary-card">
            <span>Authorised Persons</span>
            <strong>@SelectedCompany.AuthorisedPersons.Count</strong>
            <p>Manager-level and above representatives on record.</p>
        </article>
        <article class="summary-card">
            <span>Open Tasks</span>
            <strong>@SelectedCompany.Tasks.Count(task => !task.IsCompleted)</strong>
            <p>Outstanding dashboard tasks for the selected company.</p>
        </article>
    </section>

    <section class="data-panel dashboard-company-workspace">
        <div class="dashboard-company-sidebar">
            <div class="dashboard-company-sidebar-header">
                <div>
                    <p class="eyebrow">My Company</p>
                    <h2>Company List</h2>
                </div>
                <span>@($"{FilteredCompanies.Count} of {Companies.Count}")</span>
            </div>

            <div class="dashboard-company-sidebar-controls">
                <input class="input dashboard-company-search" value="@_companySearch" @oninput="OnCompanySearchInput" placeholder="Search company, city, industry, or registration no." />
            </div>

            <div class="dashboard-company-list-shell">
                <div class="dashboard-company-list">
                    @if (FilteredCompanies.Count == 0)
                    {
                        <div class="dashboard-company-empty">
                            <strong>No matching companies</strong>
                            <span>Adjust the current search to see more records.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var company in FilteredCompanies)
                        {
                            <button class="@GetCompanyCardClass(company)" type="button" @onclick="@(() => SelectCompany(company.Id))">
                                <strong>@company.Name</strong>
                                <span>@company.City</span>
                                <small>@($"{company.Applications.Count} applications")</small>
                            </button>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="dashboard-company-main">
            <div class="dashboard-company-header">
                <div>
                    <h2>@SelectedCompany.Name</h2>
                    <p>@SelectedCompany.Address</p>
                    <div class="dashboard-company-meta">
                        <span>@SelectedCompany.RegistrationNumber</span>
                        <span>@SelectedCompany.Industry</span>
                        <span>@SelectedCompany.Country</span>
                    </div>
                </div>
                <div class="dashboard-company-actions">
                    <button class="button primary" type="button" @onclick="OpenIrpmCompanyProfile">Company Profile (IRPM)</button>
                    <button class="button ghost" type="button">Payment History</button>
                    <button class="button ghost" type="button">Expatriate Module</button>
                </div>
            </div>

            <div class="dashboard-table-section">
                <div class="panel-header">
                    <div>
                        <h2>Applications</h2>
                        <p>Application activity shown for the selected company only.</p>
                    </div>
                    <div class="dashboard-table-summary">
                        <span>@($"{SelectedCompany.Applications.Count} total")</span>
                        <span>@($"{SelectedCompany.Applications.Count(application => application.Status == "In Progress")} in progress")</span>
                        <span>@($"{SelectedCompany.Applications.Count(application => application.Status == "Completed")} completed")</span>
                    </div>
                </div>

                <div class="dashboard-table-scroll">
                    <table class="dashboard-table">
                        <thead>
                            <tr>
                                <th>Application No.</th>
                                <th>MIDA Reference No.</th>
                                <th>Application</th>
                                <th>Application Type</th>
                                <th>Status</th>
                                <th>Last Updated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var application in PagedApplications)
                            {
                                <tr>
                                    <td class="dashboard-table-code">@application.ApplicationNumber</td>
                                    <td>@application.ReferenceNumber</td>
                                    <td>@application.ApplicationName</td>
                                    <td>@application.ApplicationType</td>
                                    <td>
                                        <span class="@GetApplicationStatusClass(application.Status)">@application.Status</span>
                                    </td>
                                    <td>@application.LastUpdated</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="dashboard-table-footer dashboard-table-footer--with-pagination">
                    <span>@($"Showing {ApplicationRangeStart} to {ApplicationRangeEnd} of {SelectedCompany.Applications.Count} records")</span>
                    <div class="dashboard-pagination">
                        <button class="button ghost" type="button" disabled="@(_applicationPage == 1)" @onclick="GoToPreviousApplicationPage">Previous</button>
                        @foreach (var pageNumber in ApplicationPageNumbers)
                        {
                            <button class="@(pageNumber == _applicationPage ? "button primary" : "button ghost")" type="button" @onclick="@(() => GoToApplicationPage(pageNumber))">@pageNumber</button>
                        }
                        <button class="button ghost" type="button" disabled="@(_applicationPage >= ApplicationTotalPages)" @onclick="GoToNextApplicationPage">Next</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-secondary-stack">
        <article class="data-panel">
            <div class="panel-header">
                <div>
                    <h2>Authorised Person</h2>
                    <p>Manager level or higher contacts linked to the selected company.</p>
                </div>
                <span class="dashboard-panel-note">The position must be Manager level or higher</span>
            </div>

            <div class="dashboard-table-scroll">
                <table class="dashboard-table dashboard-table--compact">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Title</th>
                            <th>Name</th>
                            <th>Citizenship</th>
                            <th>Designation</th>
                            <th>Email</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in SelectedCompany.AuthorisedPersons.Select((value, index) => new { value, index }))
                        {
                            <tr>
                                <td>@(person.index + 1)</td>
                                <td>@person.value.Title</td>
                                <td>@person.value.Name</td>
                                <td>@person.value.Citizenship</td>
                                <td>@person.value.Designation</td>
                                <td>@person.value.Email</td>
                                <td>
                                    <span class="@GetPersonStatusClass(person.value.Status)">@person.value.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>

        <article class="data-panel">
            <div class="panel-header">
                <div>
                    <h2>Task List</h2>
                    <p>Dashboard-level tasks related to the selected company.</p>
                </div>
                <button class="button ghost" type="button" @onclick="@(() => Navigation.NavigateTo("/tasks"))">View All</button>
            </div>

            <div class="dashboard-table-scroll">
                <table class="dashboard-table dashboard-table--compact">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Status</th>
                            <th>Owner</th>
                            <th>Due Date</th>
                            <th>Last Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in SelectedCompany.Tasks)
                        {
                            <tr>
                                <td>
                                    <div class="dashboard-task-cell">
                                        <strong>@task.Title</strong>
                                        <small>@task.Description</small>
                                    </div>
                                </td>
                                <td>
                                    <span class="@GetTaskStatusClass(task.Status)">@task.Status</span>
                                </td>
                                <td>@task.Owner</td>
                                <td>@task.DueDate</td>
                                <td>@task.LastUpdated</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>
    </section>
}

