    private string _selectedCompanyId = "infineon";
    private string _companySearch = string.Empty;
    private int _applicationPage = 1;
    private const int ApplicationPageSize = 4;

    private DashboardCompany SelectedCompany => Companies.FirstOrDefault(company => company.Id == _selectedCompanyId) ?? Companies[0];
    private IReadOnlyList<DashboardCompany> FilteredCompanies => Companies
        .Where(MatchesCompanySearch)
        .ToList();
    private IReadOnlyList<DashboardApplication> PagedApplications => SelectedCompany.Applications
        .Skip((CurrentApplicationPage - 1) * ApplicationPageSize)
        .Take(ApplicationPageSize)
        .ToList();
    private int ApplicationTotalPages => Math.Max(1, (int)Math.Ceiling(SelectedCompany.Applications.Count / (double)ApplicationPageSize));
    private int CurrentApplicationPage => Math.Min(Math.Max(_applicationPage, 1), ApplicationTotalPages);
    private int ApplicationRangeStart => SelectedCompany.Applications.Count == 0 ? 0 : ((CurrentApplicationPage - 1) * ApplicationPageSize) + 1;
    private int ApplicationRangeEnd => Math.Min(CurrentApplicationPage * ApplicationPageSize, SelectedCompany.Applications.Count);
    private IReadOnlyList<int> ApplicationPageNumbers => Enumerable.Range(1, ApplicationTotalPages).ToList();

    private void SelectCompany(string companyId)
    {
        _selectedCompanyId = companyId;
        _applicationPage = 1;
    }

    private void OnCompanySearchInput(ChangeEventArgs args)
    {
        _companySearch = args.Value?.ToString() ?? string.Empty;
    }

    private bool MatchesCompanySearch(DashboardCompany company)
    {
        if (string.IsNullOrWhiteSpace(_companySearch))
        {
            return true;
        }

        return company.Name.Contains(_companySearch, StringComparison.OrdinalIgnoreCase) ||
               company.City.Contains(_companySearch, StringComparison.OrdinalIgnoreCase) ||
               company.Industry.Contains(_companySearch, StringComparison.OrdinalIgnoreCase) ||
               company.RegistrationNumber.Contains(_companySearch, StringComparison.OrdinalIgnoreCase);
    }

    private void GoToApplicationPage(int pageNumber)
    {
        _applicationPage = Math.Min(Math.Max(pageNumber, 1), ApplicationTotalPages);
    }

    private void GoToPreviousApplicationPage()
    {
        if (_applicationPage > 1)
        {
            _applicationPage--;
        }
    }

    private void GoToNextApplicationPage()
    {
        if (_applicationPage < ApplicationTotalPages)
        {
            _applicationPage++;
        }
    }

    private void OpenIrpmCompanyProfile()
    {
        Navigation.NavigateTo($"/irpm/company-profile?company={Uri.EscapeDataString(_selectedCompanyId)}");
    }

    private string GetCompanyCardClass(DashboardCompany company)
    {
        return company.Id == _selectedCompanyId
            ? "dashboard-company-card dashboard-company-card--active"
            : "dashboard-company-card";
    }

    private static string GetApplicationStatusClass(string status)
    {
        return status switch
        {
            "Completed" => "table-badge table-badge--success",
            "Submitted" => "table-badge table-badge--info",
            "Resubmitted" => "table-badge table-badge--info",
            "In Progress" => "table-badge dashboard-badge-progress",
            "Rejected" => "table-badge table-badge--danger",
            _ => "table-badge table-badge--warning"
        };
    }

    private static string GetPersonStatusClass(string status)
    {
        return status switch
        {
            "Active" => "table-badge table-badge--success",
            "Pending Update" => "table-badge table-badge--warning",
            "Inactive" => "table-badge table-badge--danger",
            _ => "table-badge table-badge--info"
        };
    }

    private static string GetTaskStatusClass(string status)
    {
        return status switch
        {
            "Completed" => "table-badge table-badge--success",
            "In Progress" => "table-badge dashboard-badge-progress",
            "Pending" => "table-badge table-badge--warning",
            _ => "table-badge table-badge--info"
        };
    }

    private sealed class DashboardCompany
    {
        public string Id { get; init; } = string.Empty;
        public string Name { get; init; } = string.Empty;
        public string City { get; init; } = string.Empty;
        public string Address { get; init; } = string.Empty;
        public string RegistrationNumber { get; init; } = string.Empty;
        public string Industry { get; init; } = string.Empty;
        public string Country { get; init; } = string.Empty;
        public List<DashboardApplication> Applications { get; init; } = [];
        public List<DashboardAuthorisedPerson> AuthorisedPersons { get; init; } = [];
        public List<DashboardTaskItem> Tasks { get; init; } = [];
    }

    private sealed class DashboardApplication
    {
        public string ApplicationNumber { get; init; } = string.Empty;
        public string ReferenceNumber { get; init; } = string.Empty;
        public string ApplicationName { get; init; } = string.Empty;
        public string ApplicationType { get; init; } = string.Empty;
        public string Status { get; init; } = string.Empty;
        public string LastUpdated { get; init; } = string.Empty;
    }

    private sealed class DashboardAuthorisedPerson
    {
        public string Title { get; init; } = string.Empty;
        public string Name { get; init; } = string.Empty;
        public string Citizenship { get; init; } = string.Empty;
        public string Designation { get; init; } = string.Empty;
        public string Email { get; init; } = string.Empty;
        public string Status { get; init; } = string.Empty;
    }

    private sealed class DashboardTaskItem
    {
        public string Title { get; init; } = string.Empty;
        public string Description { get; init; } = string.Empty;
        public string Status { get; init; } = string.Empty;
        public string Owner { get; init; } = string.Empty;
        public string DueDate { get; init; } = string.Empty;
        public string LastUpdated { get; init; } = string.Empty;
        public bool IsCompleted { get; init; }
    }
