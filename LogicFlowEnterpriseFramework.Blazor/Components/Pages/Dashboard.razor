@page "/dashboard"
@using LogicFlowEnterpriseFramework.Shared.Constants
@inject AuthSession Session
@inject NavigationManager Navigation

@if (!Session.IsReady)
{
    <PageLoadingShell Title="Loading dashboard" Message="Resolving your workspace." />
}
else if (!Session.IsAuthenticated)
{
    <section class="empty-state">
        <h1>Authentication required</h1>
        <p>Sign in to access the enterprise dashboard.</p>
        <button class="button primary" @onclick="@(() => Navigation.NavigateTo("/login", replace: true))">Sign In</button>
    </section>
}

@code {
    protected override void OnParametersSet()
    {
        if (!Session.IsReady)
        {
            return;
        }

        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        Navigation.NavigateTo(ResolveDashboardRoute(), replace: true);
    }

    private string ResolveDashboardRoute()
    {
        if (IsScreeningOfficer())
        {
            return "/dashboard/screening-officer";
        }

        if (HasApplicantDashboardAccess())
        {
            return "/dashboard/applicant";
        }

        if (HasSystemAdministrationAccess() || IsSystemAdmin())
        {
            return "/configuration";
        }

        return "/dashboard/applicant";
    }

    private bool IsScreeningOfficer()
    {
        return Session.User?.Roles.Any(role =>
            string.Equals(role, "Screening Officer", StringComparison.OrdinalIgnoreCase)) == true;
    }

    private bool IsApplicant()
    {
        return Session.User?.Roles.Any(role =>
            string.Equals(role, "Applicant", StringComparison.OrdinalIgnoreCase)) == true;
    }

    private bool HasApplicantDashboardAccess()
    {
        return Session.User?.Permissions.Contains(Permissions.ApplicantDashboardRead, StringComparer.OrdinalIgnoreCase) == true ||
               IsApplicant();
    }

    private bool HasSystemAdministrationAccess()
    {
        return Session.User?.Permissions.Contains(Permissions.SystemAdminSettingsRead, StringComparer.OrdinalIgnoreCase) == true ||
               Session.User?.Permissions.Contains(Permissions.SystemAdminSettingsManage, StringComparer.OrdinalIgnoreCase) == true;
    }

    private bool IsSystemAdmin()
    {
        return Session.User?.Roles.Any(role =>
            string.Equals(role, "System Administrator", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(role, "System Admin", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase)) == true ||
            string.Equals(Session.User?.Email, "admin@logicflow.local", StringComparison.OrdinalIgnoreCase);
    }
}
